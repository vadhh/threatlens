# Copy to .env.local and fill in. Both are server-only — never exposed to the browser.

# OpenRouter API key — https://openrouter.ai/keys (free tier works)
OPENROUTER_API_KEY=

# AbuseIPDB API key — https://www.abuseipdb.com/account/api
# Optional: without it the app still runs, just skips reputation enrichment.
ABUSEIPDB_API_KEY=
